# Compendium - Environment Variables
# Copy this file to .env.local and fill in the values

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Authentication (NextAuth)
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (AI Synthesis + TTS)
OPENAI_API_KEY="sk-..."

# NewsAPI (Source fetcher)
NEWSAPI_KEY="..."

# Redis (BullMQ job queue - Upstash)
REDIS_URL="redis://default:password@upstash-redis.kv.upstash.com:6379"

# Cloudflare R2 (Audio storage)
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET="compendium-audio"
R2_ENDPOINT="https://account-id.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://audio.compendium.app"

# Email (Resend)
RESEND_API_KEY="re_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Compendium"